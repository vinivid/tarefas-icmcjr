{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,

    "rootDir": "./",
    "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "types": ["vitest/globals"],
    "paths": {
      "@/*": [
        "./*"
      ]
    },
  },
  "exclude": ["dist", "node_modules"]
}
